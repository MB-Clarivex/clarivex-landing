{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        { "type": "host", "value": "www.clarivex.ai" }
      ],
      "destination": "https://clarivex.ai/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/:path*", "destination": "/index.html" }
  ]
}







