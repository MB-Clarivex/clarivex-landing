{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "clarivex.ai" }],
      "destination": "https://www.clarivex.ai/:path*",
      "permanent": true
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}







